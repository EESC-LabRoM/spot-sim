      <origin xyz="0.00952465 -0.01144406 0.00000186"/>
      <inertia ixx="0.00046738" ixy="0.00006957" ixz="0.00000040" iyy="0.00044968" iyz="0.00000016" izz="0.00053616"/>
      <mass value="0.58263740"/>
    </inertial>
  </link>

  <link name="arm_link_wr1">
